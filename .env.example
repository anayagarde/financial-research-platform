# Copy to .env and adjust. Used by docker-compose variable substitution.

# Published host ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Browser → API (host machine). Used as build arg for Next.js public env.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Postgres (matches backend defaults in Phase 2+)
POSTGRES_USER=marfin
POSTGRES_PASSWORD=marfin_dev
POSTGRES_DB=marfin
